# Copy this file to .env before running.

# Input and output
DAIYA_INPUT_DIR=../../dataset/raw
DAIYA_OUTPUT_DIR=output/hf_dataset
# Must be a fresh, not-yet-created directory for each export.
DAIYA_WORK_DIR=work
DAIYA_DATASET_SPLIT=train
DAIYA_AUDIO_EXTENSIONS=.wav,.mp3,.m4a,.flac,.ogg,.opus,.aac,.wma,.webm,.mp4,.mov,.mkv

# FFmpeg normalization
DAIYA_FFMPEG_BIN=ffmpeg
DAIYA_FFMPEG_MAX_WORKERS=4
DAIYA_FFMPEG_MAX_IN_FLIGHT=4
DAIYA_SAMPLE_RATE=16000
DAIYA_CHANNELS=1
DAIYA_AUDIO_CODEC=pcm_s16le

# Silero VAD
DAIYA_VAD_THRESHOLD=0.5
DAIYA_VAD_MIN_SPEECH_MS=250
DAIYA_VAD_MIN_SILENCE_MS=150
DAIYA_VAD_SPEECH_PAD_MS=80

# pyannote diarization used to detect overlapped speaker turns
DAIYA_ENABLE_OVERLAP_FILTER=true
DAIYA_PYANNOTE_AUTH_TOKEN=
DAIYA_PYANNOTE_OVERLAP_MODEL=pyannote/speaker-diarization-community-1
DAIYA_OVERLAP_PAD_SECONDS=0.15

# Chunking
DAIYA_MIN_CHUNK_SECONDS=1.0
DAIYA_TARGET_CHUNK_SECONDS=18.0
DAIYA_MAX_CHUNK_SECONDS=25.0
DAIYA_MERGE_GAP_SECONDS=0.35

# Whisper transcription
DAIYA_WHISPER_MODEL=large-v3
DAIYA_WHISPER_DEVICE=cuda
DAIYA_WHISPER_COMPUTE_TYPE=auto
DAIYA_WHISPER_LANGUAGE=
DAIYA_WHISPER_BEAM_SIZE=5
DAIYA_WHISPER_BATCH_SIZE=8
DAIYA_TORCH_DEVICE=cuda

# OpenRouter cleanup through the OpenAI SDK
OPENROUTER_API_KEY=
DAIYA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DAIYA_OPENROUTER_MODEL=openai/gpt-4o-audio-preview
DAIYA_OPENROUTER_APP_NAME=Daiya-RMT
DAIYA_OPENROUTER_SITE_URL=http://localhost
DAIYA_LLM_MAX_WORKERS=2
DAIYA_LLM_MAX_IN_FLIGHT=2
DAIYA_LLM_TEMPERATURE=0.0
DAIYA_LLM_TIMEOUT_SECONDS=120
DAIYA_LLM_AUDIO_FORMAT=wav
DAIYA_ENABLE_LLM_CLEANUP=true

# Export metadata
DAIYA_LANGUAGE_HINT=mixed
DAIYA_TEXT_COLUMN=text
DAIYA_KEEP_INTERMEDIATE=false
DAIYA_EXPORT_MAX_WORKERS=4
DAIYA_EXPORT_MAX_IN_FLIGHT=4

# Labeling workbench defaults. The GUI reads these values from this file, so
# each workflow step can run with its prefilled server configuration.
DAIYA_VALIDATION_OUTPUT_DIR=output/validation
DAIYA_VALIDATION_THAI_ENGINE=pn
DAIYA_VALIDATION_EXPECTED_SCRIPTS=thai,latin
DAIYA_VALIDATION_REVIEW_THRESHOLD=0.2
DAIYA_VALIDATION_MIN_ISSUES=1
DAIYA_REVIEW_OUTPUT_DIR=web/human-reviews
# DAIYA_REVIEWER=
