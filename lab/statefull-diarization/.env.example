# Hugging Face token for gated pyannote models.
HF_TOKEN=

# Audio file to diarize. WAV, MP3, and other FFmpeg-readable formats are OK.
AUDIO_PATH=C:\path\to\audio.wav

# Pyannote pipeline model loaded with Pipeline.from_pretrained.
PYANNOTE_MODEL=pyannote/speaker-diarization-community-1

# Use cuda when available, or cpu for a CPU-only run.
DEVICE=cuda

# Legacy chunk mode only: seconds of audio analyzed by each pyannote call.
CHUNK_SECONDS=20

# Legacy chunk mode only: seconds between chunk starts. Smaller than CHUNK_SECONDS means overlap.
STRIDE_SECONDS=12

# Realtime rolling profile: balanced, fast, or accuracy.
DIARIZATION_PROFILE=balanced

# Optional overrides for the selected realtime profile.
DIARIZATION_WINDOW_SECONDS=10.0
DIARIZATION_HOP_SECONDS=1.0
DIARIZATION_LATENCY_SECONDS=3.0
DIARIZATION_COMMIT_DELAY_SECONDS=5.0

# Optional CSV path for per-hop latency/revision metrics.
METRICS_PATH=

# Maximum cosine distance allowed when matching a chunk speaker to memory.
MATCH_THRESHOLD=0.38

# Clean exclusive speech seconds needed to create a permanent speaker immediately.
MIN_NEW_PROFILE_SECONDS=6.0

# Clean exclusive speech seconds needed before a candidate can become permanent.
CANDIDATE_PROMOTE_SECONDS=3.0

# Number of matched observations needed before a candidate can become permanent.
CANDIDATE_PROMOTE_OBSERVATIONS=2

# Ask pyannote to avoid overlapped regions while extracting speaker embeddings.
EMBEDDING_EXCLUDE_OVERLAP=true

# If pyannote has zero clean non-overlap embeddings for clustering, retry with total active speech.
CLUSTER_FALLBACK_TO_ACTIVE_SPEECH=true

# Live capture source for --live: mic uses an input device; desktop uses loopback-style input.
LIVE_SOURCE=mic

# Optional live device index or name. Leave empty for default mic or auto desktop detection.
LIVE_DEVICE=

# Sample rate used for live recording.
LIVE_SAMPLE_RATE=16000
