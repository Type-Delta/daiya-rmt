# Hugging Face token for gated pyannote models.
HF_TOKEN=

# Audio file to diarize. WAV, MP3, and other FFmpeg-readable formats are OK.
AUDIO_PATH=C:\path\to\audio.wav

# Pyannote pipeline model loaded with Pipeline.from_pretrained.
PYANNOTE_MODEL=pyannote/speaker-diarization-community-1

# Use cuda when available, or cpu for a CPU-only run.
DEVICE=cuda

# Seconds of audio analyzed by each pyannote call.
CHUNK_SECONDS=20

# Seconds between chunk starts. Smaller than CHUNK_SECONDS means overlap.
STRIDE_SECONDS=12

# Maximum cosine distance allowed when matching a chunk speaker to memory.
MATCH_THRESHOLD=0.38

# Clean exclusive speech seconds needed to create a permanent speaker immediately.
MIN_NEW_PROFILE_SECONDS=6.0

# Clean exclusive speech seconds needed before a candidate can become permanent.
CANDIDATE_PROMOTE_SECONDS=3.0

# Number of matched observations needed before a candidate can become permanent.
CANDIDATE_PROMOTE_OBSERVATIONS=2

# Ask pyannote to avoid overlapped regions while extracting speaker embeddings.
EMBEDDING_EXCLUDE_OVERLAP=true
